{
  "name": "HA Pill Logger Full Stack",
  "image": "ghcr.io/home-assistant/home-assistant:stable",
  "remoteUser": "root",
  "forwardPorts": [8123],
  "runArgs": [
    "-p", "0.0.0.0:8123:8123"
  ],
  "mounts": [
    "source=${localWorkspaceFolder}/../lovelace-pill-logger-card,target=/workspaces/lovelace-pill-logger-card,type=bind",
    "source=${localWorkspaceFolder}/../lovelace-pill-logger-card/dist,target=/workspaces/Home-Assistant-Pill-Logger/config/www/pill-logger,type=bind"
  ],
  "postCreateCommand": "apk update && apk add --no-cache nodejs npm libc6-compat github-cli && npm install -g corepack && corepack enable && export COREPACK_ENABLE_DOWNLOAD_PROMPT=0 && cd /workspaces/lovelace-pill-logger-card && corepack prepare yarn@stable --activate && yarn install",
  "customizations": {
    "vscode": {
      "extensions": [
        "zoocodeorganization.zoo-code",
        "redhat.vscode-yaml",
        "charliermarsh.ruff",
        "ms-python.vscode-python-envs",
        "ms-python.debugpy",
        "ms-python.python",
        "ms-python.vscode-pylance",
        "dbaeumer.vscode-eslint",
        "bierner.lit-html",
        "runem.lit-plugin"
      ]
    }
  }
}
